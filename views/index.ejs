<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="<%= metaDescription %>" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Main navigation">
        <a class="sign-up-link" href="#signup"><%= signUpLabel %></a>

        <div class="nav-links" role="menubar" aria-label="Top navigation">
          <div class="dropdown" role="none">
            <button class="dropbtn" aria-haspopup="true" aria-expanded="false"><%= aboutUsMenuLabel %></button>
            <div class="dropdown-content" role="menu">
              <a href="/about" role="menuitem"><%= aboutHostLabel %></a>
              <a href="/about#mission" role="menuitem"><%= aboutMissionLabel %></a>
            </div>
          </div>

          <div class="dropdown" role="none">
            <button class="dropbtn" aria-haspopup="true" aria-expanded="false"><%= subscribeMenuLabel %></button>
            <div class="dropdown-content" role="menu">
              <a href="#featured" role="menuitem"><%= featuredLaunchLabel %></a>
              <a href="/episodes" role="menuitem"><%= episodeFeedLabel %></a>
            </div>
          </div>

          <div class="dropdown" role="none">
            <button class="dropbtn" aria-haspopup="true" aria-expanded="false"><%= contactMenuLabel %></button>
            <div class="dropdown-content" role="menu">
              <a href="/contact" role="menuitem"><%= guestInquiryLabel %></a>
              <a href="/contact" role="menuitem"><%= sponsorInquiryLabel %></a>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <main class="page page-full">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-content">
          <h1 id="hero-title" class="title-hero scroll-pop"><%= heroTitle %></h1>
          <p class="scroll-subtitle"><%= heroSubtitle %></p>
        </div>

        <aside id="featured" class="hero-card">
          <h2><%= featuredLaunchHeading %></h2>
          <p class="feature-blank"><%= featuredLaunchContent %></p>
        </aside>
      </section>
    </main>

    <footer class="site-footer" aria-label="Footer information">
      <div class="footer-content">
        <h3><%= siteName %></h3>
        <p><%= siteDescription %></p>
        <div class="footer-links">
          <a href="/"><%= navHomeLabel %></a>
          <a href="/about"><%= navAboutLabel %></a>
          <a href="/episodes"><%= navEpisodesLabel %></a>
          <a href="/contact"><%= navContactLabel %></a>
        </div>
      </div>

      <div class="footer-contact">
        <h3><%= getInTouchHeading %></h3>
        <div class="contact-info">
          <p>📧 <a href="mailto:<%= contactEmail %>"><%= contactEmail %></a></p>
          <p>📱 <a href="tel:<%= contactPhoneNum %>"><%= contactPhoneText %></a></p>
        </div>
        <a href="/contact" class="contact-btn"><%= contactBtnLabel %></a>
      </div>

      <div class="footer-social">
        <h3><%= connectHeading %></h3>
        <p><%= connectSubheading %></p>
        <div class="social-links">
          <a href="<%= facebookUrl %>" aria-label="Facebook">f</a>
          <a href="<%= twitterUrl %>" aria-label="Twitter">𝕏</a>
          <a href="<%= instagramUrl %>" aria-label="Instagram">📷</a>
        </div>
      </div>
    </footer>

    <div class="footer-bottom">
      <p>&copy; <%= copyrightYear %> <%= copyrightName %>. All rights reserved.</p>
    </div>

    <script src="/site.js"></script>
  </body>
</html>